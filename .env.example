# APEX BOT — ENVIRONMENT TEMPLATE
# Copy this to .env and fill in your values

X_USERNAME=your_x_username
X_EMAIL=your_x_email
X_PASSWORD=your_x_password

TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

GEMINI_API_KEY=your_gemini_api_key
TWELVE_DATA_KEY=your_twelve_data_key

WALLET_USDT_ERC20=your_usdt_erc20_address
WALLET_BTC=your_btc_address
WALLET_SOL=your_sol_address
METAWIN_ID=your_metawin_username

NODE_ENV=production
LOG_LEVEL=info
DB_PATH=./data/apex.db
LOG_PATH=./logs/apex.log

MAX_SIGNALS_PER_DAY=8
MIN_CONFLUENCE_SCORE=3
RISK_PER_TRADE=1.5
MAX_DRAWDOWN_PERCENT=10

GIVEAWAY_CHECK_ENABLED=true
MAX_ACTIONS_PER_RUN=5
MAX_DAILY_ACTIONS=20

PUPPETEER_HEADLESS=true
ACTION_DELAY_MIN=3000
ACTION_DELAY_MAX=8000
